{
  "manifest_version": 3,
  "name": "LeetCode AutoSuggest AI",
  "version": "2.0",
  "description": "An Agentic AI and NLP-powered auto-suggest tool for the LeetCode editor.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "css": [
        "styles.css"
      ],
      "js": [
        "trie.js",
        "nlp.js",
        "ai.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dictionaries/*.json"],
      "matches": ["*://leetcode.com/*"]
    }
  ]
}